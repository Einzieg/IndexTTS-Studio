# Runtime
INDEXTTS_STUDIO_HOST=127.0.0.1
INDEXTTS_STUDIO_PORT=8000
INDEXTTS_STUDIO_LOG_LEVEL=INFO

# Authentication
INDEXTTS_STUDIO_AUTH_ENABLED=false
INDEXTTS_STUDIO_AUTH_USERNAME=admin
INDEXTTS_STUDIO_AUTH_PASSWORD=admin123
INDEXTTS_STUDIO_AUTH_SESSION_SECRET=
INDEXTTS_STUDIO_AUTH_COOKIE_NAME=indextts_studio_session
INDEXTTS_STUDIO_AUTH_SESSION_TTL_SECONDS=43200
INDEXTTS_STUDIO_AUTH_SECURE_COOKIE=false
INDEXTTS_STUDIO_AUTH_SAME_SITE=lax

# Backend
INDEXTTS_STUDIO_BACKEND=remote_gradio
INDEXTTS_STUDIO_WARMUP_ON_STARTUP=true
INDEXTTS_STUDIO_GRADIO_BASE_URL=http://127.0.0.1:7861
INDEXTTS_STUDIO_GRADIO_API_PREFIX=/gradio_api
INDEXTTS_STUDIO_GRADIO_API_NAME=/gen_single

# Paths
INDEXTTS_STUDIO_ROOT=.
INDEXTTS_STUDIO_DATA_DIR=data
INDEXTTS_STUDIO_SPEAKERS_FILE=data/speakers.json
INDEXTTS_STUDIO_SCRIPTS_DIR=data/scripts
INDEXTTS_STUDIO_REFS_DIR=data/refs
INDEXTTS_STUDIO_OUTPUTS_DIR=data/outputs
INDEXTTS_STUDIO_LOGS_DIR=data/logs
INDEXTTS_STUDIO_JOBS_DIR=data/jobs

# Optional official IndexTTS checkout
INDEXTTS_STUDIO_INDEXTTS_PACKAGE_ROOT=
INDEXTTS_STUDIO_MODEL_DIR=checkpoints
INDEXTTS_STUDIO_MODEL_CFG=checkpoints/config.yaml
INDEXTTS_STUDIO_USE_FP16=false
INDEXTTS_STUDIO_USE_CUDA_KERNEL=false
INDEXTTS_STUDIO_USE_DEEPSPEED=false

# Frontend dev server
VITE_API_TARGET=http://127.0.0.1:8000
VITE_UI_DEV_HOST=127.0.0.1
VITE_UI_DEV_PORT=5173

# Docker overrides
INDEXTTS_STUDIO_DOCKER_HOST=0.0.0.0
INDEXTTS_STUDIO_DOCKER_PORT=8000
INDEXTTS_STUDIO_DOCKER_WARMUP_ON_STARTUP=false
INDEXTTS_STUDIO_DOCKER_GRADIO_BASE_URL=http://index-tts:7861

# Bundled index-tts container
INDEXTTS_CUDA_BASE_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04
INDEXTTS_UPSTREAM_REPO=https://github.com/index-tts/index-tts.git
INDEXTTS_UPSTREAM_REF=main
INDEXTTS_MODEL_SOURCE=auto
INDEXTTS_MODEL_REPO=IndexTeam/IndexTTS-2
INDEXTTS_MODELSCOPE_MODEL_ID=IndexTeam/IndexTTS-2
INDEXTTS_BOOTSTRAP_RETRIES=20
INDEXTTS_BOOTSTRAP_RETRY_DELAY=15
INDEXTTS_FORCE_CPU=false
INDEXTTS_WEBUI_FP16=true
HF_TOKEN=
HF_ENDPOINT=
INDEXTTS_NVIDIA_VISIBLE_DEVICES=all
INDEXTTS_NVIDIA_DRIVER_CAPABILITIES=compute,utility
