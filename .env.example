# Runtime
INDEXTTS_STUDIO_HOST=127.0.0.1
INDEXTTS_STUDIO_PORT=8000
INDEXTTS_STUDIO_LOG_LEVEL=INFO

# Backend
INDEXTTS_STUDIO_BACKEND=remote_gradio
INDEXTTS_STUDIO_WARMUP_ON_STARTUP=true
INDEXTTS_STUDIO_GRADIO_BASE_URL=http://127.0.0.1:7861
INDEXTTS_STUDIO_GRADIO_API_PREFIX=/gradio_api
INDEXTTS_STUDIO_GRADIO_API_NAME=/gen_single

# Paths
INDEXTTS_STUDIO_ROOT=.
INDEXTTS_STUDIO_DATA_DIR=data
INDEXTTS_STUDIO_SPEAKERS_FILE=data/speakers.json
INDEXTTS_STUDIO_SCRIPTS_DIR=data/scripts
INDEXTTS_STUDIO_REFS_DIR=data/refs
INDEXTTS_STUDIO_OUTPUTS_DIR=data/outputs
INDEXTTS_STUDIO_LOGS_DIR=data/logs

# Optional official IndexTTS checkout
INDEXTTS_STUDIO_INDEXTTS_PACKAGE_ROOT=
INDEXTTS_STUDIO_MODEL_DIR=checkpoints
INDEXTTS_STUDIO_MODEL_CFG=checkpoints/config.yaml
INDEXTTS_STUDIO_USE_FP16=false
INDEXTTS_STUDIO_USE_CUDA_KERNEL=false
INDEXTTS_STUDIO_USE_DEEPSPEED=false

# Frontend dev server
VITE_API_TARGET=http://127.0.0.1:8000
VITE_UI_DEV_HOST=127.0.0.1
VITE_UI_DEV_PORT=5173
